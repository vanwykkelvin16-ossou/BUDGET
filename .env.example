# PennyPlay — optional backend + payments
#
# Leave Supabase unset to run in local demo mode (all data stays on this device).
# To connect a real Supabase backend:
#   1. Create a project at https://supabase.com (or `supabase projects create`)
#   2. Apply the migrations in supabase/migrations/ (`supabase db push`)
#   3. Deploy edge functions:
#        supabase functions deploy award-xp
#        supabase functions deploy payfast-itn --no-verify-jwt
#   4. Copy this file to .env and fill in the values
#
# Project: BUDGET (ewvaykmaoxcumkmrjvkm, eu-central-2)
# Use the publishable key (sb_publishable_…) or legacy anon key for VITE_SUPABASE_ANON_KEY.

VITE_SUPABASE_URL=https://ewvaykmaoxcumkmrjvkm.supabase.co
VITE_SUPABASE_ANON_KEY=

# PayFast (South Africa) — PennyPlay Plus yearly subscription (R200, auto-renews).
# First year may be R150 with a referral code; renewals charge R200.
# Without these, Pay buttons run in labelled test mode and activate a local year.
# Sandbox: https://sandbox.payfast.co.za — set VITE_PAYFAST_SANDBOX=1
VITE_PAYFAST_MERCHANT_ID=
VITE_PAYFAST_MERCHANT_KEY=
VITE_PAYFAST_SANDBOX=1

# Edge function secrets (set with `supabase secrets set`, not in Vite):
#   PAYFAST_PASSPHRASE=...
#   PAYFAST_SANDBOX=1
